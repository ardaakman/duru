{
  "name": "duru",
  "version": "0.0.1",
  "description": "duru — see your Kubernetes cluster clearly: offline HTML maps from manifests or dumps (CLI), and a live map inside Headlamp (plugin)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "duru": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "build": "npm run build:web && tsc && npm run build --workspace @duru/core && npm run build --workspace headlamp-plugin-duru",
    "pretest": "npm run build:web && npm run build --workspace @duru/core",
    "test": "vitest run",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "dev": "node scripts/dev.mjs",
    "dev:headlamp": "bash dev/headlamp.sh up"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "puppeteer": "^23.11.1",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "dagre": "^0.8.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
